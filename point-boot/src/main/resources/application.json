{
  "app": {
    "name": "point",
    "description": "point — a modern forum system built with freeway"
  },
  "freeway": {
    "web": {
      "server": {
        "host": "0.0.0.0",
        "port": 8082
      },
      "cors": {
        "enabled": true,
        "allowed-origins": "*",
        "allowed-headers": "Content-Type, Authorization, X-User-Token",
        "max-age": "86400"
      }
    },
    "db": {
      "url": "jdbc:h2:file:./data/bbs;MODE=MySQL;DB_CLOSE_DELAY=-1;NON_KEYWORDS=VALUE,KEY,LABEL,TYPE,LEVEL,INDEX",
      "username": "sa",
      "password": "",
      "pool": {
        "max-size": 20
      }
    }
  },
  "bbs": {
    "jwt": {
      "secret": "change-me-in-production-use-a-long-random-string",
      "expire-days": 7
    },
    "upload": {
      "dir": "./uploads"
    },
    "oauth": {
      "github": {
        "client-id": "",
        "client-secret": "",
        "redirect-uri": "http://localhost:8082/api/auth/github/callback"
      }
    }
  }
}
