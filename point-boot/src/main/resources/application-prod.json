{
  "freeway": {
    "web": {
      "server": {
        "host": "0.0.0.0",
        "port": 8080
      },
      "cors": {
        "enabled": true,
        "allowed-origins": "https://your-domain.com"
      }
    },
    "db": {
      "url": "jdbc:mysql://localhost:3306/bbs?useSSL=true&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai",
      "username": "SET_DB_USERNAME",
      "password": "SET_DB_PASSWORD",
      "pool": {
        "max-size": 30,
        "min-idle": 5
      }
    }
  },
  "bbs": {
    "jwt": {
      "secret": "SET_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS",
      "expire-days": 7
    },
    "upload": {
      "dir": "./uploads"
    },
    "oauth": {
      "github": {
        "client-id": "SET_GITHUB_CLIENT_ID",
        "client-secret": "SET_GITHUB_CLIENT_SECRET",
        "redirect-uri": "https://your-domain.com/api/auth/github/callback"
      }
    }
  }
}
